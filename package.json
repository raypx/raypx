{
  "name": "raypx",
  "version": "0.1.0",
  "private": true,
  "description": "A modern web application built with Next.js and TypeScript",
  "homepage": "https://raypx.com",
  "bugs": {
    "url": "https://github.com/raypx/raypx/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/raypx/raypx.git"
  },
  "license": "MIT",
  "author": {
    "name": "Raypx",
    "email": "support@raypx.com"
  },
  "scripts": {
    "audit": "pnpm audit --audit-level moderate",
    "build": "turbo build",
    "bump-deps": "pnpm dlx taze -wrI",
    "changeset": "changeset",
    "check": "biome check",
    "clean": "pnpm --recursive --parallel run clean",
    "coverage": "vitest --coverage",
    "dedupe": "pnpm dedupe",
    "dev": "turbo dev",
    "format": "biome check --write",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "raypx-scripts postinstall",
    "prepare": "husky",
    "shadcn": "pnpm --filter @raypx/web run shadcn && pnpm -w format",
    "test": "turbo test --cache-dir=.turbo",
    "turbo:gen": "turbo gen",
    "update:deps": "pnpm update --recursive --interactive --latest"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.3",
    "@changesets/cli": "^2.29.5",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@raypx/scripts": "workspace:*",
    "@turbo/gen": "^2.5.5",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "^3.2.4",
    "husky": "^9.1.7",
    "rimraf": "^6.0.1",
    "turbo": "^2.5.5",
    "typescript": "catalog:",
    "vitest": "^3.2.4",
    "zod": "catalog:"
  },
  "packageManager": "pnpm@10.14.0"
}
