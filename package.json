{
  "name": "raypx",
  "version": "0.0.0",
  "private": true,
  "description": "A modern web application built with TanStack Start and TypeScript",
  "homepage": "https://raypx.com",
  "bugs": {
    "url": "https://github.com/raypx/raypx/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/raypx/raypx.git"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "Raypx",
    "email": "support@raypx.com"
  },
  "scripts": {
    "build": "turbo build",
    "changeset": "changeset",
    "check": "biome check",
    "clean": "raypx-scripts clean",
    "coverage": "vitest --coverage",
    "dev": "turbo --filter=web dev",
    "docs:dev": "turbo dev --filter docs",
    "email-preview": "turbo email-preview --filter=@raypx/email",
    "format": "raypx-scripts format",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "raypx-scripts postinstall",
    "setup": "raypx-scripts setup",
    "db:generate": "pnpm --filter @raypx/db generate",
    "db:migrate": "pnpm --filter @raypx/db migrate",
    "db:push": "pnpm --filter @raypx/db push",
    "db:studio": "pnpm --filter @raypx/db studio",
    "shadcn": "pnpm --filter web run shadcn && pnpm -w format",
    "test": "vitest",
    "turbo:gen": "pnpm turbo gen",
    "typecheck": "turbo typecheck --affected --cache-dir=.turbo",
    "update:deps": "pnpm update --recursive --interactive --latest"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:dev",
    "@changesets/cli": "^2.29.7",
    "@dotenvx/dotenvx": "^1.51.1",
    "@raypx/scripts": "workspace:*",
    "@turbo/gen": "^2.6.1",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "^4.0.9",
    "jsdom": "^27.2.0",
    "lefthook": "catalog:dev",
    "rimraf": "catalog:",
    "tsx": "^4.20.6",
    "turbo": "^2.6.1",
    "typescript": "catalog:dev",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@10.22.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10.0.0"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3"
  }
}
