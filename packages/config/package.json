{
  "name": "@raypx/config",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./server": {
      "types": "./dist/server.d.mts",
      "import": "./dist/server.mjs"
    },
    "./envs": {
      "types": "./dist/envs/index.d.mts",
      "import": "./dist/envs/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist .turbo",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@raypx/env": "^0.0.3"
  },
  "devDependencies": {
    "@raypx/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:dev",
    "vitest": "catalog:"
