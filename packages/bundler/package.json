{
  "name": "@raypx/bundler",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "default": "./dist/index.mjs",
        "types": "./dist/index.d.mts"
      },
      "require": {
        "default": "./dist/index.cjs",
        "types": "./dist/index.d.cts"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist .turbo",
    "test": "vitest",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@raypx/env": "workspace:*",
    "fs-extra": "catalog:",
    "lodash-es": "catalog:"
  },
  "devDependencies": {
    "@raypx/tsconfig": "workspace:*",
    "@types/fs-extra": "catalog:",
    "@types/lodash-es": "catalog:",
    "@types/node": "catalog:",
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "catalog:"
  }
}
