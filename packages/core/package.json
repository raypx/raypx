    "test": "vitest run",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@raypx/env": "catalog:",
    "vite": "catalog:"
  },
  "devDependencies": {
    "@raypx/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:dev",
    "vitest": "catalog:"
  }
