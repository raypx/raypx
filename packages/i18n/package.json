{
  "name": "@raypx/i18n",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "require": "./dist/server.cjs",
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    },
    "./messages": {
      "require": "./dist/messages.cjs",
      "import": "./dist/messages.js",
      "types": "./dist/messages.d.ts"
    },
    "./runtime": {
      "require": "./dist/runtime.cjs",
      "import": "./dist/runtime.js",
      "types": "./dist/runtime.d.ts"
    },
    "./inlang": {
      "import": "./dist/inlang.js",
      "require": "./dist/inlang.cjs",
      "types": "./dist/inlang.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rimraf dist .turbo",
    "test": "vitest",
    "build:i18n": "tsdown",
    "postinstall": "pnpm build:i18n && paraglide-js compile --project ./inlang --outdir ./paraglide",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@raypx/env": "workspace:*",
    "urlpattern-polyfill": "^10.1.0"
  },
  "devDependencies": {
    "@inlang/cli": "^3.0.12",
    "@inlang/paraglide-js": "^2.4.0",
    "@raypx/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "^0.15.9",
    "typescript": "catalog:dev",
    "vitest": "catalog:"
  }
}
