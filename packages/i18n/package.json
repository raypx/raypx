{
  "name": "@raypx/i18n",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "default": "./index.js",
      "types": "./index.d.ts"
    },
    "./server": {
      "default": "./server.js",
      "require": "./server.js",
      "types": "./server.d.ts"
    },
    "./messages": {
      "default": "./messages.js",
      "require": "./messages.js",
      "types": "./messages.d.ts"
    },
    "./runtime": {
      "default": "./runtime.js",
      "require": "./runtime.js",
      "types": "./runtime.d.ts"
    },
    "./compile": {
      "default": "./compile.js",
      "require": "./compile.js",
      "types": "./compile.d.ts"
    }
  },
  "scripts": {
    "#build": "tsdown",
    "clean": "rimraf dist .turbo",
    "test": "vitest",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@inlang/cli": "^3.0.12",
    "@inlang/paraglide-js": "^2.4.0",
    "@raypx/env": "workspace:*",
    "lodash-es": "^4.17.21",
    "urlpattern-polyfill": "^10.1.0"
  },
  "devDependencies": {
    "@raypx/tsconfig": "workspace:*",
    "@types/lodash-es": "catalog:",
    "@types/node": "catalog:",
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "catalog:"
  }
}
